class ChexKeyPatcher : EventHandler
{
	override void CheckReplacement(ReplaceEvent ChexKeyPatch)
	{
		// replaces chex keys with doom keycards
		if (ChexKeyPatch.Replacee == 'ChexBlueCard' && ChexKeyReplace == 1)
		{
			ChexKeyPatch.Replacement = 'BlueCard';
		}
		if (ChexKeyPatch.Replacee == 'ChexRedCard' && ChexKeyReplace == 1)
		{
			ChexKeyPatch.Replacement = 'RedCard';
		}
		if (ChexKeyPatch.Replacee == 'ChexYellowCard' && ChexKeyReplace == 1)
		{
			ChexKeyPatch.Replacement = 'YellowCard';
		}
		// replaces chex flemkeys with doom skull keys
		if (ChexKeyPatch.Replacee == 'BlueFlemKey' && ChexKeyReplace == 1)
		{
			ChexKeyPatch.Replacement = 'BlueSkull';
		}
		if (ChexKeyPatch.Replacee == 'RedFlemKey' && ChexKeyReplace == 1)
		{
			ChexKeyPatch.Replacement = 'RedSkull';
		}
		if (ChexKeyPatch.Replacee == 'YellowFlemKey' && ChexKeyReplace == 1)
		{
			ChexKeyPatch.Replacement = 'YellowSkull';
		}
		// replaces doom keycards with chex keys
		// due to the way lockdefs is currently set, this breaks things
		if (ChexKeyPatch.Replacee == 'BlueCard' && ChexKeyReplace == 2)
		{
			ChexKeyPatch.Replacement = 'ChexBlueCard';
		}
		if (ChexKeyPatch.Replacee == 'RedCard' && ChexKeyReplace == 2)
		{
			ChexKeyPatch.Replacement = 'ChexRedCard';
		}
		if (ChexKeyPatch.Replacee == 'YellowCard' && ChexKeyReplace == 2)
		{
			ChexKeyPatch.Replacement = 'ChexYellowCard';
		}
		// replaces doom skull keys with chex flemkeys
		// due to the way lockdefs is currently set, this breaks things
		if (ChexKeyPatch.Replacee == 'BlueSkull' && ChexKeyReplace == 2)
		{
			ChexKeyPatch.Replacement = 'BlueFlemKey';
		}
		if (ChexKeyPatch.Replacee == 'RedSkull' && ChexKeyReplace == 2)
		{
			ChexKeyPatch.Replacement = 'RedFlemKey';
		}
		if (ChexKeyPatch.Replacee == 'YellowSkull' && ChexKeyReplace == 2)
		{
			ChexKeyPatch.Replacement = 'YellowFlemKey';
		}
	}
}

