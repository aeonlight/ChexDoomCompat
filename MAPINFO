GameInfo
{
	// this adds this mod's zscript event handles (the item replacers) to every map
	AddEventHandlers = "ChexKeyPatcher", "ChexPickupPatcher", "ChexAmmoPatcher", "ChexWeapPatcher"
	// this adds a custom playerclass to the menus, which uses both games' weaps
	// originally I wanted to include the doom and chex players as options too
	// but I couldn't figure out how to prevent the new game class select menu
	PlayerClasses = "PatchHybridPlayer"
	NoRandomPlayerClass = true
}
